# Example .env for wordcracker. Copy to `.env` and customize.
#
# WC_IMAGE_TAG pins the wordcracker-textlab image tag for compose.
# On prod it is the short git SHA written by scripts/deploy.sh; the
# prod path (`docker compose -f docker-compose.yml ...` or
# `bash scripts/deploy.sh`) refuses to run without it.
#
# Per D-SB1-7 the dev override file is `docker-compose.dev.yml` and is
# NOT auto-applied. Bare `docker compose up` on prod loads only
# docker-compose.yml — the safe default. To get dev behaviour
# (bind-mounts, `:-dev` tag fallback) on bare `docker compose up`,
# uncomment the COMPOSE_FILE line below.
#
# See docs/v2/decisions.md → 2026-05-24 S-B1 (D-SB1-7 addendum).

WC_IMAGE_TAG=dev

# Dev opt-in (uncomment to make bare `docker compose up` load dev too):
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
