# Example .env for wordcracker. Copy to `.env` and customize.
#
# WC_IMAGE_TAG pins the gutenberg-lab image tag for `docker compose up`.
# On prod it is the short git SHA written by scripts/deploy.sh. On dev
# the docker-compose.override.yml provides a `:-dev` fallback, so a
# missing .env still works locally (but `docker compose -f
# docker-compose.yml` — the prod path — refuses to run without it).
#
# See docs/v2/decisions.md → 2026-05-24 S-B1.

WC_IMAGE_TAG=dev
