# игнорируем данные и временные файлы
data/
raw_books/
__pycache__/
*.pyc
*.ipynb_checkpoints
/media/

# D-SB1-3: .env carries the per-host WC_IMAGE_TAG (and any future
# per-host secrets). .env.example is committed as a template.
.env

# S-B7: prod-root clutter that kept ~24 files showing as untracked in
# `git status` (and so in deploy.sh's dirty-check noise). Anchored to the
# repo root with a leading `/` so we don't mask a legitimately-tracked
# *.bak / test_report_*.md somewhere under the tree. The files themselves
# are deleted on prod separately.
/test_report_*.md
/*.bak

# R-30 WP-0 §7: the autonomy audit-log is written at runtime on the prod
# host by scripts/autonomy/deploy_runner.py (append-only; Stan reads it).
# Never committed — a tracked AUTONOMY_LOG.md would also be a scope-fence
# DENY path. Anchored to the repo root.
/AUTONOMY_LOG.md
