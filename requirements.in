# Top-level runtime deps for the gutenberg-lab image (ADR-B1).
#
# This is the SOURCE of truth — list only direct dependencies.
# Transitive deps are pinned in requirements.lock, generated by:
#
#     bash build_lockfile.sh
#
# Run that script on the PROD host (Linux/CUDA 12.4) — the lock is
# platform-specific (torch wheel selection differs between
# linux/win/cuda variants). Re-run + commit lock whenever this file
# changes. The lock is the deploy artifact; this file is the intent.

# Notebook surface (gutenberg-lab also runs jupyter on 8888)
jupyterlab

# NLP stack
nltk
spacy[transformers]
transformers
sentencepiece
sentence-transformers

# Data / tabular
pandas
numpy
pyarrow                  # parquet IO for /workspace/spgc/derived/*.parquet (ADR-A1)

# Plotting (notebooks; safe to keep in runtime image)
matplotlib
seaborn

# ML
scikit-learn

# Vector store
chromadb

# Text utilities
beautifulsoup4
ebooklib
ftfy
unidecode
regex
more-itertools

# CLI / display
tqdm
typer
rich

# HTTP (Ollama calls — see scripts/rag_query.py:176)
requests

# Web API — S6 wordcracker-api service (docs/webapp.md, decisions D17)
fastapi>=0.135           # встроенный fastapi.sse (EventSourceResponse)
uvicorn[standard]        # был транзитивным (chromadb) — теперь прямой деп
openpyxl                 # xlsx-экспорт (/api/export/xlsx)

# Test infra (used by the predeploy harness — ADR-B4)
pytest
